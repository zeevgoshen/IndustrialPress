{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Sensor": {
    "Count": 20,
    "IntervalSeconds": 1
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Exchange": "telemetry.events",
    "RoutingKey": "sensor.updated"
  }
}
