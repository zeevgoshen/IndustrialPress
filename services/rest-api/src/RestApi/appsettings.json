{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sensor": {
    "Count": 20
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "User": "industrial",
    "Password": "industrial",
    "Exchange": "telemetry.events",
    "RoutingKey": "sensor.updated",
    "Queue": "telemetry.sensor-updates",
    "Prefetch": 20
  },
  "Grpc": {
    "SqlData": "http://localhost:5102"
  }
}
